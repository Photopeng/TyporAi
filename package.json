{
  "name": "typorai",
  "version": "2.0.27",
  "description": "TyporAi - AI assistant embedded in Typora sidebar",
  "main": "typora-typorai.js",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "postinstall": "node scripts/postinstall.mjs",
    "build:css": "node scripts/build-css.mjs",
    "dev": "npm run dev:typora",
    "dev:typora": "npm run build:css && node esbuild.config.mjs typora",
    "build": "npm run build:typora",
    "build:typora": "node scripts/build.mjs production typora",
    "build:macos-renderer": "node esbuild.macos-renderer.config.mjs production",
    "build:renderer": "node esbuild.renderer.config.mjs production",
    "build:legacy": "node scripts/build.mjs production typora",
    "build:sidecar": "node esbuild.sidecar.config.mjs production",
    "build:sidecar-v1": "node esbuild.sidecar-v1.config.mjs production",
    "build:all": "npm run build:css && npm run build:renderer && npm run build:legacy && npm run build:sidecar && npm run build:sidecar-v1",
    "package:release": "node scripts/package-release.mjs",
    "deploy:typora": "npm run build:all && node scripts/deploy-typora.mjs install",
    "install:typora": "npm run deploy:typora",
    "uninstall:typora": "node scripts/deploy-typora.mjs uninstall",
    "repair:typora": "npm run build:all && node scripts/deploy-typora.mjs repair",
    "verify:typora": "node scripts/deploy-typora.mjs verify",
    "typecheck": "tsc --noEmit",
    "typecheck:typora": "tsc --noEmit -p tsconfig.typora.json",
    "audit:architecture": "node scripts/architecture-audit.mjs",
    "audit:renderer": "npm run build:renderer && node scripts/audit-renderer.mjs",
    "verify:sidecar": "node scripts/verify-sidecar.mjs",
    "lint": "eslint \"{src,tests}/**/*.ts\"",
    "lint:fix": "npm run lint -- --fix",
    "test": "node scripts/run-jest.js",
    "test:watch": "node scripts/run-jest.js --watch",
    "test:coverage": "node scripts/run-jest.js --coverage",
    "test:protocol": "node scripts/run-jest.js --runInBand tests/unit/protocol",
    "test:contract": "node scripts/run-jest.js --runInBand tests/contract tests/unit/bridge",
    "test:integration": "node scripts/run-jest.js --selectProjects integration",
    "version": "node scripts/sync-version.js && git add manifest.json"
  },
  "keywords": [
    "claude-code",
    "typora",
    "typora-plugin",
    "productivity",
    "ide"
  ],
  "author": "Yishen Tu",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.2",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.0",
    "eslint-plugin-jest": "^29.15.1",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "ts-jest": "^29.4.9",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.159",
    "@codemirror/state": "^6.5.0",
    "@codemirror/view": "^6.38.6",
    "@modelcontextprotocol/sdk": "~1.29.0",
    "smol-toml": "^1.6.1",
    "tslib": "^2.8.1",
    "ws": "^8.21.1"
  },
  "overrides": {
    "@babel/core": "7.29.7",
    "hono": "4.12.26",
    "js-yaml": "4.2.0"
  }
}
